# =============================================================================
# GOLD AI TRADING INTELLIGENCE PLATFORM — Environment Template
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=goldai
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=goldai
POSTGRES_HOST_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=6379

# ── Security (REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX_STRING

# ── Admin seed account (created on first startup) ────────────────────────────
ADMIN_EMAIL=admin@gold.ai
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML ────────────────────────────────────────────────────────────────────────
ML_MODEL_DIR=/app/models

# ── CORS (comma-separated allowed origins) ───────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# ── External APIs ─────────────────────────────────────────────────────────────
# Twelvedata: https://twelvedata.com → Account → API Keys
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# Telegram: https://t.me/BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=

# ── Observability ─────────────────────────────────────────────────────────────
# Sentry: https://sentry.io → Create Project → DSN
SENTRY_DSN=

# ── Signal Engine Thresholds ──────────────────────────────────────────────────
SIGNAL_BUY_THRESHOLD=62
SIGNAL_SELL_THRESHOLD=38
SIGNAL_MIN_CONFIDENCE=65

# ── Docker port overrides (for local development) ────────────────────────────
WEB_HOST_PORT=8001

# ── Internal service URL (used by Telegram bot inside Docker) ────────────────
INTERNAL_BASE_URL=http://backend:8001

# ── MT5 (optional — for live trading) ────────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ── Data providers (optional additional providers) ───────────────────────────
# POLYGON_API_KEY=your_polygon_api_key
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
