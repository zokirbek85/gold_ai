# ============================================================
# GOLD AI TRADING INTELLIGENCE PLATFORM v2.0 — Environment
# ============================================================

# ---- Core ----
ENV=development
PROJECT_NAME=gold-ai
SECRET_KEY=change_me_to_a_long_random_string

# ---- Database ----
DATABASE_URL=postgresql+psycopg2://gold:goldpass@localhost:5432/gold_ai

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- JWT ----
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- MetaTrader 4 — ZeroMQ Bridge ----
# Host where MT4 is running (use Windows machine IP for cross-machine setup)
MT4_HOST=localhost
# ZeroMQ ports — must match the EA settings in MT4
MT4_CMD_PORT=32768
MT4_DATA_PORT=32769
MT4_SYMBOLS=XAUUSD,EURUSD
MT4_TIMEFRAMES=1,5,15,60,240
MT4_INGEST_INTERVAL_SECONDS=60
INDICATOR_CALC_INTERVAL_SECONDS=120

# ---- Historical market data ----
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
# ---- AI (configure at least one for AI analysis) ----
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# ---- Telegram ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=

# ---- Machine Learning ----
ML_MODEL_DIR=models

# ---- News ----
NEWS_INGEST_INTERVAL_SECONDS=1800

# ---- Docker port mapping ----
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6379
WEB_HOST_PORT=8001

# Notes:
# - Password hashing uses PBKDF2-HMAC-SHA256 (no C-extension needed)
# - ML packages (xgboost, lightgbm, catboost) are optional; system works without them
# - MT4 connects via ZeroMQ bridge EA — see MT4_CONNECTION_GUIDE.md
# - pyzmq must be installed: pip install pyzmq
# - The connector gracefully degrades when the EA is not running
